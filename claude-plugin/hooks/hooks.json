{
  "PreToolUse": [
    {
      "matcher": "Bash|Write|Edit|NotebookEdit",
      "hooks": [
        {
          "type": "command",
          "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/brain-gate.sh",
          "timeout": 15
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Bash|Write|Edit|NotebookEdit",
      "hooks": [
        {
          "type": "command",
          "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/outcome-record.sh",
          "timeout": 5
        }
      ]
    }
  ]
}
